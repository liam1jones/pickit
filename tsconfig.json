{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/main.tsx",
    "src/vite-env.d.ts",
    "src/lib/integrations/**/*.ts",
    "src/lib/roles/**/*.ts",
    "src/lib/cores/vendors/**/*.ts",
    "src/lib/dummyData/**/*.ts",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
  ]
}
